# =============================================================
# Meterplex — Local Development Environment
# These values MUST match the docker compose services.
# If they don't match, the app can't connect to Postgres/Kafka/Redis.
# =============================================================

# --- Application ---
NODE_ENV=development
PORT=3000
# API_PREFIX and API_VERSION control the global route prefix.
# All routes will be: /api/v1/tenants, /api/v1/usage, etc.
API_PREFIX=api
API_VERSION=v1

# --- Database (Postgres) ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
# These credentials match docker/docker-compose.yml exactly.
DATABASE_URL="postgresql://meterplex:meterplex_dev@localhost:5432/meterplex?schema=public"

# --- Kafka ---
# KAFKA_BROKERS: comma-separated list. Single broker for local dev.
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=meterplex
KAFKA_CONSUMER_GROUP=meterplex-group

# --- Redis (cache + rate limiting) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Logging ---
# Options: error, warn, info, http, verbose, debug, silly
LOG_LEVEL=debug

# --- CORS ---
# Comma-separated origins allowed to call this API.
# Add your frontend dev server URL here.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Rate Limiting ---
# THROTTLE_TTL: window in seconds. THROTTLE_LIMIT: max requests per window.
# 100 requests per 60 seconds per IP.
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# --- Auth (JWT) ---
# Used to sign and verify JWT tokens.
# In production, use a long random string from a secret manager.
# NEVER use this default in production.
JWT_SECRET=meterplex-dev-jwt-secret-change-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=meterplex-dev-refresh-secret-change-in-production
JWT_REFRESH_EXPIRATION=7d