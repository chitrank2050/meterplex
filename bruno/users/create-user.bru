meta {
  name: Create User in Tenant
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/{{apiPrefix}}/v1/users
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

headers {
  x-tenant-id: {{tenantId}}
}

body:json {
  {
    "email": "newuser@example.com",
    "password": "SecurePass123",
    "firstName": "New",
    "lastName": "User"
  }
}