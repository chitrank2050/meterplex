meta {
  name: Health Check
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/health
  body: none
  auth: none
}

docs {
  Returns 200 if all dependencies (Postgres, Kafka, Redis) are healthy.
  Returns 503 if any dependency is down.

  No auth required. No API prefix - health is excluded from /api/v1.
}