meta {
  name: Create Entitlement (BOOLEAN)
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/{{apiPrefix}}/v1/plans/{{planId}}/entitlements
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "featureId": "{{featureId}}",
    "value": true
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setEnvVar("entitlementId", res.body.id);
  }
}