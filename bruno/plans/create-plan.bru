meta {
  name: Create Plan
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/{{apiPrefix}}/v1/plans
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "name": "Pro Plus",
    "slug": "pro-plus",
    "description": "For teams that need even more power.",
    "displayOrder": 4,
    "metadata": {
      "trialDays": 21
    }
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setEnvVar("planId", res.body.id);
  }
}