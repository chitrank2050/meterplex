meta {
  name: Get Plan by Slug (pro)
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/{{apiPrefix}}/v1/plans/slug/pro
  auth: none
}

script:post-response {
  if (res.status === 200) {
    bru.setEnvVar("proPlanId", res.body.id);
    const monthly = res.body.prices.find(p => p.interval === "MONTHLY");
    if (monthly) bru.setEnvVar("proMonthlyPriceId", monthly.id);
  }
}