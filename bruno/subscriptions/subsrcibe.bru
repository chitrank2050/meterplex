meta {
  name: Subscribe Tenant to Plan
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/{{apiPrefix}}/v1/subscriptions
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

headers {
  x-tenant-id: {{tenantId}}
}

body:json {
  {
    "planId": "{{proPlanId}}",
    "priceId": "{{proMonthlyPriceId}}"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setEnvVar("subscriptionId", res.body.id);
  }
}