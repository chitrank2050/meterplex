meta {
  name: Create Feature (BOOLEAN)
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/{{apiPrefix}}/v1/features
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "name": "Custom Domains",
    "lookupKey": "custom_domains",
    "type": "BOOLEAN",
    "description": "Use your own domain for hosted pages"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setEnvVar("featureId", res.body.id);
  }
}