meta {
  name: Change Password
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/{{apiPrefix}}/v1/auth/change-password
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "currentPassword": "DevPass123",
    "newPassword": "NewPass456"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setEnvVar("accessToken", res.body.accessToken);
    bru.setEnvVar("refreshToken", res.body.refreshToken);
  }
}