meta {
  name: Login
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/{{apiPrefix}}/v1/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "dev@meterplex.com",
    "password": "DevPass123"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setEnvVar("accessToken", res.body.accessToken);
    bru.setEnvVar("refreshToken", res.body.refreshToken);
  }
}