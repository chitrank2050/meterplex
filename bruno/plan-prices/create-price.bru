meta {
  name: Add Price to Plan
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/{{apiPrefix}}/v1/plans/{{planId}}/prices
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "interval": "MONTHLY",
    "amount": 14900,
    "currency": "usd"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setEnvVar("priceId", res.body.id);
  }
}