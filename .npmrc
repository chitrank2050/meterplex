# Prevent strict engine mismatch crashes (development flexibility)
engine-strict=false

# Auto-install peer dependencies (essential for NestJS packages)
auto-install-peers=true

# Keep CLI output quiet but show warnings
loglevel=warn

# Speed up installations by skipping redundant logs and sync network audits
audit=false
fund=false
update-notifier=false

# Hoist dependencies to root node_modules for NestJS plugin compatibility
hoist=true
shamefully-hoist=true
hoist-workspace-packages=false

# Avoid Docker volume and macOS file permission/sync errors
package-import-method=clone-or-copy
