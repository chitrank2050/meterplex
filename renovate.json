{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":timezone(Asia/Kolkata)",
    "mergeConfidence:all-badges",
    "helpers:pinGitHubActionDigests"
  ],
  "labels": ["dependencies", "renovate"],
  "assignees": ["chitrank2050"],
  "gitAuthor": "Chitrank Agnihotri <chitrank2050@gmail.com>",
  "baseBranchPatterns": ["main"],
  "schedule": ["every weekend"],
  "prBodyColumns": ["Package", "Change", "Age", "Confidence"],
  "packageRules": [
    {
      "matchPackageNames": [
        "eslint",
        "prettier",
        "typescript-eslint",
        "markdownlint-cli",
        "knip",
        "eslint-config-prettier",
        "@trivago/prettier-plugin-sort-imports"
      ],
      "groupName": "linting & formatting"
    },
    {
      "matchPackageNames": ["typescript"],
      "groupName": "typescript core",
      "versioning": "npm"
    },
    {
      "matchPackageNames": ["/@nestjs\//", "@nestjs/cli", "@nestjs/schematics"],
      "groupName": "nestjs ecosystem"
    },
    {
      "matchPackageNames": ["prisma", "/@prisma\//"],
      "groupName": "prisma & database"
    },
    {
      "matchPackageNames": [
        "vitest",
        "/@vitest\//",
        "supertest",
        "@types/supertest"
      ],
      "groupName": "testing ecosystem"
    },
    {
      "matchPackageNames": ["/@types\//"],
      "matchUpdateTypes": ["patch", "minor"],
      "groupName": "definitely typed (non-major)",
      "automerge": true
    },
    {
      "matchUpdateTypes": ["patch", "minor"],
      "matchPackageNames": ["*"],
      "groupName": "non-major dependencies",
      "automerge": true
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "github-actions dependencies",
      "pinDigests": true
    }
  ],
  "dependencyDashboard": true,
  "prConcurrentLimit": 10,
  "prHourlyLimit": 2,
  "vulnerabilityAlerts": {
    "enabled": true
  },
  "platformAutomerge": true
}
