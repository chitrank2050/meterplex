{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":timezone(Asia/Kolkata)"],
  "labels": ["dependencies", "renovate"],
  "assignees": ["chitrank2050"],
  "reviewers": ["chitrank2050"],
  "gitAuthor": "Chitrank agnihotri <chitrank2050@gmail.com>",
  "baseBranches": ["main"],
  "schedule": ["every weekend"],
  "packageRules": [
    {
      "matchPackagePatterns": ["^@nestjs/"],
      "groupName": "nestjs",
      "automerge": true
    },
    {
      "matchPackagePatterns": ["^prisma", "^@prisma/"],
      "groupName": "prisma",
      "automerge": true
    },
    {
      "matchPackagePatterns": ["eslint", "prettier", "typescript-eslint"],
      "groupName": "linting & formatting"
    },
    {
      "matchPackageNames": ["typescript"],
      "groupName": "typescript",
      "versioning": "npm"
    },
    {
      "matchUpdateTypes": ["patch", "minor"],
      "matchPackagePatterns": [".*"],
      "automerge": true
    },
    {
      "matchFileNames": ["experimental/**"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    }
  ],
  "dependencyDashboard": true,
  "prConcurrentLimit": 10,
  "prHourlyLimit": 2,
  "vulnerabilityAlerts": {
    "enabled": false
  }
}
