{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":timezone(Asia/Kolkata)",
    ":dependencyDashboard",
    ":semanticCommits",
    ":separateMajorReleases",
    "mergeConfidence:all-badges",
    "helpers:pinGitHubActionDigests"
  ],
  "labels": [
    "dependencies",
    "renovate"
  ],
  "assignees": [
    "chitrank2050"
  ],
  "gitAuthor": "Chitrank Agnihotri <chitrank2050@gmail.com>",
  "baseBranchPatterns": [
    "main"
  ],
  "schedule": [
    "every weekend"
  ],
  "prBodyColumns": [
    "Package",
    "Change",
    "Age",
    "Confidence"
  ],
  "packageRules": [
    {
      "matchPackageNames": [
        "eslint",
        "prettier",
        "typescript-eslint",
        "markdownlint-cli",
        "knip",
        "eslint-config-prettier",
        "@trivago/prettier-plugin-sort-imports"
      ],
      "groupName": "linting & formatting"
    },
    {
      "matchPackageNames": [
        "typescript"
      ],
      "groupName": "typescript core",
      "versioning": "npm"
    },
    {
      "matchPackageNames": [
        "/@nestjs\//",
        "@nestjs/cli",
        "@nestjs/schematics"
      ],
      "groupName": "nestjs ecosystem"
    },
    {
      "matchPackageNames": [
        "prisma",
        "/@prisma\//"
      ],
      "groupName": "prisma & database"
    },
    {
      "matchPackageNames": [
        "vitest",
        "/@vitest\//",
        "supertest",
        "@types/supertest"
      ],
      "groupName": "testing ecosystem"
    },
    {
      "matchPackageNames": [
        "/@types\//"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "groupName": "definitely typed (non-major)",
      "automerge": true
    },
    {
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "matchPackageNames": [
        "*"
      ],
      "groupName": "non-major dependencies",
      "automerge": true
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "github-actions dependencies",
      "pinDigests": true
    }
  ],
  "lockFileMaintenance": {
    "enabled": false
  },
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": [
      "security",
      "vulnerability"
    ]
  },
  "osvVulnerabilityAlerts": true,
  "dependencyDashboard": true,
  "prConcurrentLimit": 10,
  "prHourlyLimit": 2,
  "platformAutomerge": true,
  "branchPrefix": "renovate/",
  "commitMessagePrefix": "chore: ",
  "commitMessageTopic": "{{depName}}",
  "commitMessageExtra": "to {{newVersion}}",
  "commitMessageAction": "Update",
  "ignoreDeps": [],
  "ignorePaths": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**"
  ],
  "enabledManagers": [
    "npm",
    "dockerfile",
    "github-actions"
  ],
  "npmrc": "auto-detect",
  "updateNotScheduled": false,
  "rangeStrategy": "bump"
}