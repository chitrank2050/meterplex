// =============================================================
// Meterplex - Prisma Schema
//
// This file is the SINGLE SOURCE OF TRUTH for our database.
// Every table, column, index, and relation is defined here.
//
// Workflow:
//   1. Edit this file
//   2. Run `pnpm db:migrate:dev` → creates a migration SQL file
//   3. Run `pnpm db:generate` → regenerates the typed client
//
// NOTE: Database connection URL is configured in prisma.config.ts,
// NOT here. Prisma 7 moved runtime config out of the schema file.
// =============================================================

generator client {
  // Generates a fully typed TypeScript client.
  // Output lands in /generated/prisma/ (excluded from Git).
  provider = "prisma-client"
  output   = "../generated/prisma"

  // CRITICAL: NestJS compiles to CommonJS. Prisma 7 defaults to ESM.
  // Without this, we get "exports is not defined in ES module scope".
  moduleFormat = "cjs"
}

datasource db {
  // Only the provider is declared here.
  // The connection URL is in prisma.config.ts (Prisma 7 requirement).
  provider = "postgresql"
}

// =============================================================
// Tenant - The top-level entity in a multi-tenant SaaS platform.
//
// Every resource in Meterplex belongs to a tenant:
//   Tenant → Users, Plans, Subscriptions, Usage Records, Invoices
//
// Design decisions:
//   - UUID primary keys (not auto-increment integers)
//     → Safe for distributed systems, no sequential ID guessing
//   - slug for URL-friendly tenant identification (/api/v1/tenants/acme)
//   - status enum for soft lifecycle management (no hard deletes)
//   - @@map("tenants") maps PascalCase model to snake_case table name
//   - @map("created_at") maps camelCase fields to snake_case columns
//     Prisma models use camelCase (TypeScript convention).
//     Postgres tables use snake_case (SQL convention).
// =============================================================

/// Lifecycle status of a tenant account.
enum TenantStatus {
  ACTIVE
  SUSPENDED
  CANCELLED

  @@map("tenant_status")
}

/**
 * Key decisions explained:
 * - @db.Uuid - tells Postgres to use its native uuid type, not varchar(36). Native UUIDs are stored as 16 bytes (half the size), indexed faster, and validated at the database level. If we try to insert "not-a-uuid", Postgres rejects it before our app code sees it.
 * - @db.VarChar(255) - explicit length constraint. Without it, Prisma uses text which has no limit. A tenant name doesn't need 10MB - constrain it at the DB level.
 * - slug with @unique - creates a unique index in Postgres. Two tenants can't have the same slug. The index also makes findUnique({ where: { slug } }) fast - O(log n) instead of full table scan.
 * - Json with @db.JsonB - JSONB, not JSON. JSONB is binary, indexable, and queryable with Postgres operators. JSON is just a text blob. Always use JSONB.
 * - @@map("tenants") - Prisma model is Tenant (PascalCase, TypeScript convention). Database table is tenants (snake_case, SQL convention). @map("created_at") does the same for columns. Our TypeScript code writes tenant.createdAt, the SQL query says created_at. Best of both worlds.
 */
/// A tenant represents a customer organization on the platform.
model Tenant {
  /// UUID v4 primary key - generated by Postgres, not the app.
  id String @id @default(uuid()) @db.Uuid

  /// Human-readable company name. Not unique - two companies can share a name.
  name String @db.VarChar(255)

  /// URL-safe identifier. Must be unique. Used in API paths and subdomains.
  /// Example: "acme-corp" → /api/v1/tenants/acme-corp
  slug String @unique @db.VarChar(100)

  /// Current lifecycle status. Defaults to ACTIVE on creation.
  /// SUSPENDED = billing issue, features disabled but data preserved.
  /// CANCELLED = tenant requested deletion, data retained per policy.
  status TenantStatus @default(ACTIVE)

  /// Flexible metadata bag for tenant-specific settings.
  /// Example: { "timezone": "America/New_York", "billingEmail": "..." }
  /// JSONB in Postgres = indexed, queryable, no schema enforcement.
  metadata Json @default("{}") @db.JsonB

  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  memberships   Membership[]
  apiKeys       ApiKey[]
  subscriptions Subscription[]

  @@map("tenants")
}

// =============================================================
// User - Global account, not tenant-scoped.
//
// A user has one email and one password across the entire platform.
// They can belong to multiple tenants via memberships.
// This is how Slack, Notion, and GitHub work - one login, many orgs.
//
// Design decisions:
//   - Email is globally unique (not per-tenant)
//   - Password is bcrypt-hashed, never stored in plain text
//   - is_active allows soft-disabling without deleting
//   - No tenant_id here - that's on the membership
// =============================================================

model User {
  /// UUID v4 primary key.
  id String @id @default(uuid()) @db.Uuid

  /// Login email. Globally unique across all tenants.
  email String @unique @db.VarChar(255)

  /// Bcrypt hash of the password. Never store plain text.
  /// The $ prefix in bcrypt hashes identifies the algorithm version.
  passwordHash String @map("password_hash") @db.VarChar(255)

  /// Display name fields.
  firstName String @map("first_name") @db.VarChar(100)
  lastName  String @map("last_name") @db.VarChar(100)

  /// Soft-disable flag. Set to false to block login without deleting data.
  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  /// Relations
  memberships         Membership[]
  apiKeys             ApiKey[]             @relation("ApiKeyCreator")
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

// =============================================================
// MembershipRole - The four roles a user can have within a tenant.
//
// OWNER:     Full control. Can delete tenant, manage billing, transfer ownership.
//            Every tenant must have exactly one owner.
// ADMIN:     Can manage users, settings, API keys. Cannot delete tenant.
// DEVELOPER: Can use APIs, view usage. Cannot manage users or billing.
// BILLING:   Can view invoices, manage payment methods. Cannot access APIs.
//
// These are fixed roles, not a dynamic RBAC system. Four roles is
// enough for a billing platform. If we need custom permissions
// later, add a roles table with a permissions JSONB column.
// =============================================================

enum MembershipRole {
  OWNER
  ADMIN
  DEVELOPER
  BILLING

  @@map("membership_role")
}

// =============================================================
// Membership - Connects a user to a tenant with a role.
//
// This is the join table that enables multi-tenant users.
// User X can be OWNER of Tenant A and DEVELOPER in Tenant B.
//
// Composite unique on (user_id, tenant_id) - one membership
// per user per tenant. A user can't have two roles in the
// same tenant. If we need that, switch to a roles array.
// =============================================================

model Membership {
  /// UUID v4 primary key.
  id String @id @default(uuid()) @db.Uuid

  /// The user who belongs to this tenant.
  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// The tenant the user belongs to.
  tenantId String @map("tenant_id") @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// The user's role within this tenant.
  role MembershipRole @default(DEVELOPER)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  /// One membership per user per tenant.
  @@unique([userId, tenantId])
  @@map("memberships")
}

// =============================================================
// ApiKeyStatus - Lifecycle of an API key.
//
// ACTIVE:  Key is valid and can authenticate requests.
// REVOKED: Key has been manually revoked. Cannot be re-activated.
// EXPIRED: Key passed its expires_at date. Automatically invalid.
// =============================================================

enum ApiKeyStatus {
  ACTIVE
  REVOKED
  EXPIRED

  @@map("api_key_status")
}

// =============================================================
// ApiKey - Server-to-server authentication token.
//
// How it works (same pattern as Stripe, GitHub, AWS):
//   1. User creates a key via API → gets the raw key ONCE
//   2. We store only the SHA-256 hash (like a password)
//   3. key_prefix stores first 8 chars (e.g., "mp_live_ab...")
//      so users can identify which key is which in a list
//   4. On each API request, we hash the provided key and
//      look up the hash in the database
//
// Security:
//   - Raw key is shown once, never stored or logged
//   - Hash comparison is constant-time (prevents timing attacks)
//   - Expiration + revocation support key rotation
//   - last_used_at tracks active vs stale keys
// =============================================================

model ApiKey {
  /// UUID v4 primary key.
  id String @id @default(uuid()) @db.Uuid

  /// The tenant this key authenticates for.
  tenantId String @map("tenant_id") @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// The user who created this key (audit trail).
  createdByUserId String @map("created_by_user_id") @db.Uuid
  createdByUser   User   @relation("ApiKeyCreator", fields: [createdByUserId], references: [id])

  /// First 8 characters of the raw key. For display only.
  /// Example: "mp_live_a" - enough to identify, not enough to use.
  keyPrefix String @map("key_prefix") @db.VarChar(20)

  /// SHA-256 hash of the full key. This is what we look up on auth.
  keyHash String @unique @map("key_hash") @db.VarChar(64)

  /// Human-readable label. "Production key", "CI/CD pipeline", etc.
  name String @db.VarChar(255)

  /// Current lifecycle status.
  status ApiKeyStatus @default(ACTIVE)

  /// Optional expiration. Null means no expiration.
  expiresAt DateTime? @map("expires_at")

  /// Updated on every successful authentication.
  lastUsedAt DateTime? @map("last_used_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("api_keys")
}

// =============================================================
// RefreshToken - Tracks issued refresh tokens per user.
//
// Why store refresh tokens in the database?
//   - Enables instant revocation (logout, password change, compromise)
//   - Supports "revoke all sessions" for security incidents
//   - Access tokens are stateless (no DB lookup per request)
//   - Refresh tokens are stateful (DB lookup only on refresh, every 15min)
//
// Security:
//   - Only the SHA-256 hash is stored (like API keys)
//   - Raw token shown once at login, never stored server-side
//   - Tokens are scoped to a user agent / device (future: device management)
//   - Old tokens are cleaned up on login and refresh
// =============================================================

model RefreshToken {
  /// UUID v4 primary key.
  id String @id @default(uuid()) @db.Uuid

  /// The user this token belongs to.
  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// SHA-256 hash of the refresh token. Never store the raw token.
  tokenHash String @unique @map("token_hash") @db.VarChar(64)

  /// When this token expires. Checked on every refresh attempt.
  expiresAt DateTime @map("expires_at")

  /// Tracks if this token has been explicitly revoked (logout).
  isRevoked Boolean @default(false) @map("is_revoked")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("refresh_tokens")
}

// =============================================================
// PasswordResetToken - Tracks password reset requests.
//
// Flow:
//   1. User requests reset → POST /auth/forgot-password
//   2. We generate a crypto-random token, store its SHA-256 hash
//   3. The raw token is returned in the response (in production,
//      this would be sent via email - for now, returned directly)
//   4. User submits token + new password → POST /auth/reset-password
//   5. We hash the submitted token, look up the hash, verify expiry
//   6. Password is updated, token is marked as used
//
// Security:
//   - Raw token is never stored (only SHA-256 hash)
//   - Tokens expire after 15 minutes
//   - Tokens are single-use (is_used flag)
//   - Rate limiting on the forgot-password endpoint (added later)
//   - All active refresh tokens are revoked on password change
// =============================================================

model PasswordResetToken {
  /// UUID v4 primary key.
  id String @id @default(uuid()) @db.Uuid

  /// The user requesting the reset.
  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// SHA-256 hash of the reset token. Never store the raw token.
  tokenHash String @unique @map("token_hash") @db.VarChar(64)

  /// When this token expires. Default: 15 minutes from creation.
  expiresAt DateTime @map("expires_at")

  /// Marked true after the token is successfully used.
  /// Prevents replay attacks (using the same token twice).
  isUsed Boolean @default(false) @map("is_used")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("password_reset_tokens")
}

// =============================================================
// AuditAction - What type of mutation was performed.
// =============================================================

enum AuditAction {
  CREATE
  UPDATE
  DELETE

  @@map("audit_action")
}

// =============================================================
// AuditActorType - Who performed the action.
//
// USER:    Authenticated via JWT (dashboard user)
// API_KEY: Authenticated via API key (server-to-server)
// SYSTEM:  Internal operations (cron jobs, migrations, seed scripts)
// =============================================================

enum AuditActorType {
  USER
  API_KEY
  SYSTEM

  @@map("audit_actor_type")
}

// =============================================================
// AuditLog - Immutable record of every mutation in the system.
//
// Why a database table instead of structured logs?
//   - Queryable: "Show all changes Alice made to Acme Corp last week"
//   - Reliable: log aggregators can lose data, Postgres won't
//   - Required: billing platforms must prove who changed what
//   - Indexable: fast lookups by tenant, actor, resource, time range
//
// Design decisions:
//   - No foreign keys to other tables. Audit logs must survive
//     even if the referenced record is deleted. If a user is
//     removed, their audit trail remains.
//   - JSONB for changes allows flexible before/after diffs
//     without schema changes per resource type.
//   - Immutable: no updatedAt column. Audit logs are append-only.
//     Nobody edits an audit log - that defeats the purpose.
//   - ip_address and userAgent for forensics.
//   - correlationId links back to the full request log.
// =============================================================

model AuditLog {
  /// UUID v4 primary key.
  id String @id @default(uuid()) @db.Uuid

  /// The tenant this action was performed on.
  /// Stored as plain string, NOT a foreign key - survives tenant deletion.
  tenantId String @map("tenant_id") @db.Uuid

  /// Who performed the action. User UUID or API key UUID.
  actorId String @map("actor_id") @db.VarChar(255)

  /// How the actor authenticated.
  actorType AuditActorType @map("actor_type")

  /// What type of mutation: CREATE, UPDATE, or DELETE.
  action AuditAction

  /// Which resource type was affected: "tenant", "user", "api_key", etc.
  resource String @db.VarChar(100)

  /// UUID of the specific resource that was affected.
  resourceId String @map("resource_id") @db.VarChar(255)

  /// What changed. Shape depends on action:
  ///   CREATE: { "after": { ...full created object } }
  ///   UPDATE: { "before": { ...old fields }, "after": { ...new fields } }
  ///   DELETE: { "before": { ...full deleted object } }
  changes Json @default("{}") @db.JsonB

  /// Client IP address for forensics.
  ipAddress String? @map("ip_address") @db.VarChar(45)

  /// Client user agent string.
  userAgent String? @map("user_agent") @db.VarChar(500)

  /// Links this audit record to the full request log.
  correlationId String? @map("correlation_id") @db.VarChar(36)

  /// When the action occurred. Immutable - no updatedAt.
  createdAt DateTime @default(now()) @map("created_at")

  /// Indexes for common query patterns:
  ///   - By tenant (all activity in an org)
  ///   - By actor (all actions by a user)
  ///   - By resource (history of a specific record)
  ///   - By time (recent activity)
  @@index([tenantId])
  @@index([actorId])
  @@index([resource, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}

// =============================================================
// PlanStatus - Lifecycle of a plan.
//
// ACTIVE:   Plan is available for new subscriptions.
// ARCHIVED: Plan is retired. Existing subscribers keep it,
//           but no new subscriptions can be created.
//           Never delete a plan - archive it. Existing
//           subscriptions reference it, and invoices need
//           the plan name for receipts.
// =============================================================

enum PlanStatus {
  ACTIVE
  ARCHIVED

  @@map("plan_status")
}

// =============================================================
// Plan - What you sell. "Starter", "Pro", "Enterprise".
//
// A plan is the product identity - it does NOT contain pricing.
// Pricing lives in PlanPrice (separate table) so you can have
// $99/month and $948/year for the same plan without duplication.
//
// This mirrors Stripe's Product/Price separation (2026 API).
// Stripe deprecated their old Plans API in favor of this pattern
// because baking price into the plan means creating a new plan
// every time you change pricing. With separation, "Pro" stays
// as one entity forever, and you attach/archive prices freely.
//
// Design decisions:
//   - slug is the URL-safe identifier (used in API paths)
//   - is_public controls visibility on pricing pages
//   - display_order controls sorting on pricing pages
//   - metadata for custom attributes (trial days, support tier, etc.)
//   - ARCHIVED status instead of deletion (billing compliance)
// =============================================================

model Plan {
  /// UUID v4 primary key.
  id String @id @default(uuid()) @db.Uuid

  /// Human-readable plan name. "Starter", "Pro", "Enterprise".
  name String @db.VarChar(255)

  /// URL-safe unique identifier. Used in API paths and pricing pages.
  /// Example: "pro" → /api/v1/plans/pro
  slug String @unique @db.VarChar(100)

  /// Optional marketing description shown on pricing pages.
  description String? @db.Text

  /// Current lifecycle status. ARCHIVED plans can't get new subscribers.
  status PlanStatus @default(ACTIVE)

  /// Whether this plan appears on public pricing pages.
  /// False = hidden/custom/enterprise plans visible only via direct link.
  isPublic Boolean @default(true) @map("is_public")

  /// Controls display order on pricing pages. Lower = first.
  /// Starter = 1, Pro = 2, Enterprise = 3.
  displayOrder Int @default(0) @map("display_order")

  /// Flexible metadata bag for plan-specific settings.
  /// Example: { "trialDays": 14, "supportTier": "priority" }
  metadata Json @default("{}") @db.JsonB

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  /// Relations
  prices        PlanPrice[]
  entitlements  Entitlement[]
  subscriptions Subscription[]

  @@map("plans")
}

// =============================================================
// BillingInterval - How often the customer is charged.
//
// MONTHLY: Charged every month on the billing anchor date.
// ANNUALLY: Charged once per year. Typically discounted (e.g., 2 months free).
// =============================================================

enum BillingInterval {
  MONTHLY
  ANNUALLY

  @@map("billing_interval")
}

// =============================================================
// PlanPrice - Pricing for a plan at a specific interval + currency.
//
// The same plan can have multiple prices:
//   Pro = $99/month, $948/year, €89/month, €948/year
//
// This is Stripe's Prices API pattern. You change pricing by
// archiving the old price and creating a new one - existing
// subscribers keep the old price until renewal.
//
// Design decisions:
//   - amount is stored in the smallest currency unit (cents for USD,
//     pence for GBP). $99.00 = 9900. This avoids floating-point
//     rounding errors that would corrupt billing calculations.
//   - currency is ISO 4217 (usd, eur, gbp). Always lowercase.
//   - is_active allows archiving old prices without deletion.
//   - Unique constraint on (plan, interval, currency) prevents
//     duplicate active prices for the same combination.
// =============================================================

model PlanPrice {
  /// UUID v4 primary key.
  id String @id @default(uuid()) @db.Uuid

  /// The plan this price belongs to.
  planId String @map("plan_id") @db.Uuid
  plan   Plan   @relation(fields: [planId], references: [id], onDelete: Cascade)

  /// Billing frequency: monthly or annually.
  interval BillingInterval

  /// Price in smallest currency unit. $99.00 = 9900 cents.
  /// Integer to avoid floating-point rounding errors in billing math.
  amount Int

  /// ISO 4217 currency code, lowercase. "usd", "eur", "gbp".
  currency String @default("usd") @db.VarChar(3)

  /// Whether this price can be used for new subscriptions.
  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  /// Relations
  subscriptions Subscription[]

  @@unique([planId, interval, currency])
  @@index([planId])
  @@map("plan_prices")
}

// =============================================================
// FeatureType - How a feature is gated and consumed.
//
// BOOLEAN: On or off. "Does this plan include SSO?"
// QUOTA:   Numeric limit with reset period. "50,000 API calls/month"
// METERED: Usage-based billing. "$0.02/GB after 10GB free"
// =============================================================

enum FeatureType {
  BOOLEAN
  QUOTA
  METERED

  @@map("feature_type")
}

// =============================================================
// Feature - The global catalog of capabilities your platform offers.
//
// Features exist independently of plans. They are the "nouns"
// of your system: "API Calls", "SSO", "Webhooks", "Storage".
//
// A feature's type determines how entitlements work for it:
//   BOOLEAN → entitlement has a true/false value
//   QUOTA   → entitlement has a numeric limit + reset period
//   METERED → entitlement has per-unit pricing + optional free tier
//
// The lookup_key is the programmatic identifier used in code:
//   GET /entitlements/api_access/check
// This is the Stripe pattern - code references lookup_key, not UUID.
//
// Design decisions:
//   - lookup_key is the stable code-facing identifier (like Stripe)
//   - unit is the human-readable measurement unit ("calls", "GB", "seats")
//   - Features are ARCHIVED, never deleted (entitlements reference them)
// =============================================================

model Feature {
  /// UUID v4 primary key.
  id String @id @default(uuid()) @db.Uuid

  /// Human-readable feature name. "API Calls", "SSO", "Storage".
  name String @db.VarChar(255)

  /// Stable programmatic identifier used in entitlement checks.
  /// Example: "api_calls", "sso", "storage", "webhooks"
  /// This is what your code checks: GET /entitlements/api_calls/check
  lookupKey String @unique @map("lookup_key") @db.VarChar(100)

  /// How this feature is gated: BOOLEAN (on/off), QUOTA (limit),
  /// or METERED (usage-based pricing).
  type FeatureType

  /// Human-readable measurement unit for QUOTA and METERED features.
  /// "calls", "GB", "seats", "messages". Null for BOOLEAN features.
  unit String? @db.VarChar(50)

  /// Optional description for documentation and pricing pages.
  description String? @db.Text

  /// Current lifecycle status. Same enum as Plan for consistency.
  status PlanStatus @default(ACTIVE)

  /// Flexible metadata bag.
  metadata Json @default("{}") @db.JsonB

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  /// Relations
  entitlements Entitlement[]

  @@map("features")
}

// =============================================================
// LimitBehavior - What happens when a tenant exceeds their quota.
//
// HARD: Request is blocked. "You've used 50,000/50,000 API calls."
// SOFT: Request succeeds but overage is charged. "Usage beyond
//       50,000 calls is billed at $0.001/call."
// =============================================================

enum LimitBehavior {
  HARD
  SOFT

  @@map("limit_behavior")
}

// =============================================================
// ResetPeriod - When quota counters reset to zero.
//
// MONTHLY:  Resets on the billing anchor date each month.
// ANNUALLY: Resets once per year on the subscription anniversary.
// NEVER:    Lifetime quota - once consumed, it's gone.
// =============================================================

enum ResetPeriod {
  MONTHLY
  ANNUALLY
  NEVER

  @@map("reset_period")
}

// =============================================================
// Entitlement - The bridge between Plan and Feature.
//
// "The Pro plan grants API Calls with a limit of 50,000/month"
// "The Enterprise plan grants SSO (boolean: true)"
// "The Pro plan grants Storage at $0.02/GB after 10GB free"
//
// The columns flex based on feature type:
//
//   BOOLEAN:
//     value = true, everything else null
//
//   QUOTA:
//     limit = 50000
//     resetPeriod = MONTHLY
//     limitBehavior = HARD (blocked) or SOFT (overage charged)
//     overagePrice = null (hard) or 100 (soft, $0.001/unit in cents)
//
//   METERED:
//     includedAmount = 10 (first 10 units free)
//     overagePrice = 200 ($0.02/unit in cents - wait, see note below)
//     resetPeriod = MONTHLY
//
// overagePrice is stored in 1/100th of the smallest currency unit
// (micro-cents) to handle sub-cent pricing like $0.001/API call.
// $0.001 = 100 micro-cents. $0.02 = 2000 micro-cents.
// This avoids decimals entirely in billing math.
//
// Design decisions:
//   - Unique constraint on (plan_id, feature_id) - one entitlement
//     per feature per plan. A plan can't grant the same feature twice.
//   - limit_behavior is on the entitlement, not the feature, because
//     the same feature can be hard-capped on Starter and soft-capped
//     on Pro.
//   - overagePrice in micro-cents (integer) avoids floating-point math.
// =============================================================

model Entitlement {
  /// UUID v4 primary key.
  id String @id @default(uuid()) @db.Uuid

  /// The plan that grants this entitlement.
  planId String @map("plan_id") @db.Uuid
  plan   Plan   @relation(fields: [planId], references: [id], onDelete: Cascade)

  /// The feature being granted.
  featureId String  @map("feature_id") @db.Uuid
  feature   Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  /// For BOOLEAN features: true = granted, false = explicitly denied.
  value Boolean?

  /// For QUOTA features: the numeric limit per reset period.
  /// Example: 50000 (API calls per month).
  limit Int?

  /// What happens when the limit is exceeded: block or charge overage.
  /// Only relevant for QUOTA features.
  limitBehavior LimitBehavior? @map("limit_behavior")

  /// Price per unit beyond the limit (for SOFT quotas) or beyond
  /// includedAmount (for METERED features).
  /// Stored in micro-cents (1/10000th of currency unit).
  /// $0.001/call = 10 micro-cents. $0.02/GB = 200 micro-cents.
  overagePrice Int? @map("overage_price")

  /// For METERED features: units included before overage charges apply.
  /// Example: 10 (first 10 GB free, then $0.02/GB).
  includedAmount Int? @map("included_amount")

  /// When the quota counter resets: MONTHLY, ANNUALLY, or NEVER.
  resetPeriod ResetPeriod? @map("reset_period")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  /// One entitlement per feature per plan.
  @@unique([planId, featureId])
  @@index([planId])
  @@index([featureId])
  @@map("entitlements")
}

// =============================================================
// SubscriptionStatus - Lifecycle of a subscription.
//
// ACTIVE:    Subscription is current and paid.
// TRIALING:  In free trial period. Becomes ACTIVE when trial ends.
// PAST_DUE:  Payment failed. Grace period before cancellation.
// CANCELLED: Subscription ended. Access removed.
// PAUSED:    Temporarily halted. Can be resumed.
// =============================================================

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELLED
  PAUSED

  @@map("subscription_status")
}

// =============================================================
// Subscription - Binds a Tenant to a Plan + Price.
//
// "Acme Corp is subscribed to the Pro plan at $99/month,
// started on April 1st, renews on the 1st of each month."
//
// A tenant has exactly ONE active subscription at a time.
// Upgrades/downgrades create a new subscription and cancel the old one.
// This keeps the audit trail clean - every subscription is immutable
// once created, with only status changes allowed.
//
// Design decisions:
//   - billingAnchor is the day-of-month for recurring charges.
//     If a customer subscribes on the 15th, they're always charged
//     on the 15th. This is how Stripe handles billing anchors.
//   - trialEndsAt supports free trial periods. During trial,
//     status = TRIALING. When trial ends, status → ACTIVE and
//     first charge is created.
//   - cancelledAt records when cancellation was requested.
//     The subscription may still be active until currentPeriodEnd
//     (cancel-at-end-of-period behavior).
//   - No foreign key to entitlements - entitlement snapshots
//     are linked via the subscription ID (see EntitlementSnapshot).
// =============================================================

model Subscription {
  /// UUID v4 primary key.
  id String @id @default(uuid()) @db.Uuid

  /// The tenant that holds this subscription.
  tenantId String @map("tenant_id") @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// The plan the tenant is subscribed to.
  planId String @map("plan_id") @db.Uuid
  plan   Plan   @relation(fields: [planId], references: [id])

  /// The specific price (interval + amount + currency) for this subscription.
  priceId String    @map("price_id") @db.Uuid
  price   PlanPrice @relation(fields: [priceId], references: [id])

  /// Current lifecycle status.
  status SubscriptionStatus @default(ACTIVE)

  /// Start of the current billing period.
  currentPeriodStart DateTime @map("current_period_start")

  /// End of the current billing period. Next charge happens here.
  currentPeriodEnd DateTime @map("current_period_end")

  /// Day-of-month for recurring charges (1-28).
  /// Capped at 28 to avoid month-length edge cases (Feb 28/29/30/31).
  billingAnchor Int @map("billing_anchor")

  /// When the free trial ends. Null if no trial.
  trialEndsAt DateTime? @map("trial_ends_at")

  /// When cancellation was requested. Null if not cancelled.
  /// Subscription stays active until currentPeriodEnd.
  cancelledAt DateTime? @map("cancelled_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  /// Relations
  entitlementSnapshots EntitlementSnapshot[]

  @@index([tenantId])
  @@index([planId])
  @@map("subscriptions")
}

// =============================================================
// EntitlementSnapshot - Frozen copy of entitlements at subscribe time.
//
// Why snapshot?
//   When Acme Corp subscribes to Pro, we freeze the entitlements:
//     "API Calls: 50,000/month, SSO: true, Storage: $0.02/GB"
//
//   If we later change Pro to "API Calls: 25,000/month", Acme Corp
//   keeps their 50,000 until renewal. The snapshot is their contract.
//
// This is what Stripe does internally - they maintain "active
// entitlements" per customer that only update on subscription changes.
//
// The entitlement check service reads from snapshots, NOT from
// the plan's current entitlements. This ensures price/limit changes
// never silently affect existing subscribers.
//
// Design decisions:
//   - Mirrors the Entitlement table structure exactly
//   - Linked to subscription (not plan) so it survives plan changes
//   - featureLookupKey denormalized for fast lookups without joins
//   - Immutable: no updatedAt. Created once, never modified.
// =============================================================

model EntitlementSnapshot {
  /// UUID v4 primary key.
  id String @id @default(uuid()) @db.Uuid

  /// The subscription this snapshot belongs to.
  subscriptionId String       @map("subscription_id") @db.Uuid
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  /// Denormalized feature lookup key for fast entitlement checks.
  /// "api_calls", "sso", "storage" - no join to Feature table needed.
  featureLookupKey String @map("feature_lookup_key") @db.VarChar(100)

  /// Feature type at the time of snapshot.
  featureType FeatureType @map("feature_type")

  /// Snapshotted entitlement values - same semantics as Entitlement.
  value          Boolean?
  limit          Int?
  limitBehavior  LimitBehavior? @map("limit_behavior")
  overagePrice   Int?           @map("overage_price")
  includedAmount Int?           @map("included_amount")
  resetPeriod    ResetPeriod?   @map("reset_period")

  createdAt DateTime @default(now()) @map("created_at")

  /// One snapshot per feature per subscription.
  @@unique([subscriptionId, featureLookupKey])
  @@index([subscriptionId])
  @@index([featureLookupKey])
  @@map("entitlement_snapshots")
}
