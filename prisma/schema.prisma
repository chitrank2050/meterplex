// =============================================================
// Meterplex — Prisma Schema
//
// This file is the SINGLE SOURCE OF TRUTH for your database.
// Every table, column, index, and relation is defined here.
//
// Workflow:
//   1. Edit this file
//   2. Run `pnpm prisma:migrate:dev` → creates a migration SQL file
//   3. Run `pnpm prisma:generate` → regenerates the typed client
//
// NOTE: Database connection URL is configured in prisma.config.ts,
// NOT here. Prisma 7 moved runtime config out of the schema file.
// =============================================================

generator client {
  // Generates a fully typed TypeScript client.
  // Output lands in /generated/prisma/ (excluded from Git).
  provider = "prisma-client"
  output   = "../generated/prisma"

  // CRITICAL: NestJS compiles to CommonJS. Prisma 7 defaults to ESM.
  // Without this, you get "exports is not defined in ES module scope".
  moduleFormat = "cjs"
}

datasource db {
  // Only the provider is declared here.
  // The connection URL is in prisma.config.ts (Prisma 7 requirement).
  provider = "postgresql"
}

// =============================================================
// Models will be added here as we build each module.
// =============================================================

// =============================================================
// Tenant — The top-level entity in a multi-tenant SaaS platform.
//
// Every resource in Meterplex belongs to a tenant:
//   Tenant → Users, Plans, Subscriptions, Usage Records, Invoices
//
// Design decisions:
//   - UUID primary keys (not auto-increment integers)
//     → Safe for distributed systems, no sequential ID guessing
//   - slug for URL-friendly tenant identification (/api/v1/tenants/acme)
//   - status enum for soft lifecycle management (no hard deletes)
//   - @@map("tenants") maps PascalCase model to snake_case table name
//   - @map("created_at") maps camelCase fields to snake_case columns
//     Prisma models use camelCase (TypeScript convention).
//     Postgres tables use snake_case (SQL convention).
// =============================================================

/// Lifecycle status of a tenant account.
enum TenantStatus {
  ACTIVE
  SUSPENDED
  CANCELLED

  @@map("tenant_status")
}

/**
 * Key decisions explained:
 * - @db.Uuid — tells Postgres to use its native uuid type, not varchar(36). Native UUIDs are stored as 16 bytes (half the size), indexed faster, and validated at the database level. If you try to insert "not-a-uuid", Postgres rejects it before your app code sees it.
 * - @db.VarChar(255) — explicit length constraint. Without it, Prisma uses text which has no limit. A tenant name doesn't need 10MB — constrain it at the DB level.
 * - slug with @unique — creates a unique index in Postgres. Two tenants can't have the same slug. The index also makes findUnique({ where: { slug } }) fast — O(log n) instead of full table scan.
 * - Json with @db.JsonB — JSONB, not JSON. JSONB is binary, indexable, and queryable with Postgres operators. JSON is just a text blob. Always use JSONB.
 * - @@map("tenants") — Prisma model is Tenant (PascalCase, TypeScript convention). Database table is tenants (snake_case, SQL convention). @map("created_at") does the same for columns. Your TypeScript code writes tenant.createdAt, the SQL query says created_at. Best of both worlds.
 */
/// A tenant represents a customer organization on the platform.
model Tenant {
  /// UUID v4 primary key — generated by Postgres, not the app.
  id String @id @default(uuid()) @db.Uuid

  /// Human-readable company name. Not unique — two companies can share a name.
  name String @db.VarChar(255)

  /// URL-safe identifier. Must be unique. Used in API paths and subdomains.
  /// Example: "acme-corp" → /api/v1/tenants/acme-corp
  slug String @unique @db.VarChar(100)

  /// Current lifecycle status. Defaults to ACTIVE on creation.
  /// SUSPENDED = billing issue, features disabled but data preserved.
  /// CANCELLED = tenant requested deletion, data retained per policy.
  status TenantStatus @default(ACTIVE)

  /// Flexible metadata bag for tenant-specific settings.
  /// Example: { "timezone": "America/New_York", "billingEmail": "..." }
  /// JSONB in Postgres = indexed, queryable, no schema enforcement.
  metadata Json @default("{}") @db.JsonB

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("tenants")
}
