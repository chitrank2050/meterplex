{
  "name": "meterplex",
  "private": false,
  "version": "0.4.2",
  "description": "Open-source B2B usage metering, entitlements, and billing platform.",
  "homepage": "https://github.com/chitrank2050/meterplex#readme",
  "author": {
    "name": "Chitrank agnihotri",
    "email": "chitrank2050@gmail.com",
    "url": "https://wwww.chitrankagnihotri.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chitrank2050/meterplex"
  },
  "bugs": {
    "url": "https://github.com/chitrank2050/meterplex/issues"
  },
  "keywords": [
    "meterplex",
    "metering",
    "entitlements",
    "billing",
    "billing-engine",
    "usage-based-billing",
    "saas",
    "open-source",
    "nestjs",
    "prisma",
    "kafka",
    "redis",
    "postgres",
    "quota-management"
  ],
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md,yml,yaml}\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "pnpm run lint:ts && pnpm run lint:md",
    "lint:ts": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:md": "markdownlint \"**/*.md\" --ignore node_modules --ignore CHANGELOG.md",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:debug": "vitest --inspect-brk --inspect --logHeapUsage --threads=false",
    "test:e2e": "vitest run --config ./vitest.config.e2e.ts",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:clean": "docker compose down -v --remove-orphans",
    "docker:logs": "docker compose logs -f",
    "docker:prune": "pnpm docker:down && docker system prune -a -f --volumes",
    "init": "./scripts/install.sh",
    "nuke": "./scripts/obliviate.sh",
    "clean-setup": "pnpm run nuke && pnpm run init",
    "prepare": "husky",
    "git-tag": "./scripts/git-tag.sh",
    "git-release": "./scripts/git-release.sh"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.18",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.1.1",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@scalar/nestjs-api-reference": "^1.1.6",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "compression": "^1.8.1",
    "helmet": "^8.1.0",
    "kafkajs": "^2.2.4",
    "nest-winston": "^1.10.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "pg": "^8.16.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.17",
    "@nestjs/schematics": "^11.0.10",
    "@nestjs/testing": "^11.1.18",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.24",
    "@trivago/prettier-plugin-sort-imports": "^5.2.1",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.0",
    "@types/node": "^25.5.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "dotenv": "^17.4.1",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "markdownlint-cli": "^0.44.0",
    "prettier": "^3.4.2",
    "prisma": "^7.7.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.58.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.4"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.md": [
      "markdownlint --fix"
    ]
  },
  "pnpm": {
    "overrides": {
      "handlebars": ">=4.7.9",
      "hono": ">=4.12.4",
      "path-to-regexp": ">=8.4.0",
      "picomatch": ">=4.0.4",
      "effect": ">=3.20.0",
      "lodash": "^4.18.1",
      "@hono/node-server": ">=1.19.13",
      "glob": ">=10.5.0"
    }
  }
}
