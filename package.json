{
  "name": "meterplex",
  "private": false,
  "version": "0.5.4",
  "description": "Open-source B2B usage metering, entitlements, and billing platform.",
  "homepage": "https://github.com/chitrank2050/meterplex#readme",
  "author": {
    "name": "Chitrank agnihotri",
    "email": "chitrank2050@gmail.com",
    "url": "https://wwww.chitrankagnihotri.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chitrank2050/meterplex"
  },
  "bugs": {
    "url": "https://github.com/chitrank2050/meterplex/issues"
  },
  "keywords": [
    "meterplex",
    "metering",
    "entitlements",
    "billing",
    "billing-engine",
    "usage-based-billing",
    "saas",
    "open-source",
    "nestjs",
    "prisma",
    "kafka",
    "redis",
    "postgres",
    "quota-management"
  ],
  "scripts": {
    "// --- 🚀 Core ---": "",
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "// --- 🧹 Hygiene ---": "",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md,yml,yaml}\"",
    "lint": "pnpm run lint:ts && pnpm run lint:md && pnpm run lint:actions && pnpm run lint:knip",
    "lint:ts": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:md": "markdownlint \"**/*.md\" --fix --ignore node_modules --ignore CHANGELOG.md",
    "lint:actions": "zizmor .github/workflows/",
    "lint:branch": "validate-branch-name",
    "lint:knip": "knip",
    "// --- 🧪 Testing ---": "",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:debug": "vitest --inspect-brk --inspect --logHeapUsage --threads=false",
    "test:e2e": "vitest run --config ./vitest.config.e2e.ts",
    "// --- 💎 Database ---": "",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "// --- 🏗️ Infrastructure ---": "",
    "docker:clean:setup": "./scripts/docker-clean.sh && ./scripts/docker-setup.sh",
    "docker:setup": "./scripts/docker-setup.sh",
    "docker:ui": "docker compose --profile debug up -d",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:clean": "./scripts/docker-clean.sh",
    "docker:logs": "docker compose logs -f",
    "docker:prune": "pnpm docker:down && docker system prune -a -f --volumes",
    "// --- ⚙️ Maintenance ---": "",
    "init": "./scripts/install.sh",
    "nuke": "./scripts/obliviate.sh",
    "init:fresh": "pnpm run nuke && pnpm run init",
    "prepare": "lefthook install",
    "deps:update": "pnpm update --interactive --latest",
    "dev:init": "node ./scripts/wizard.mjs",
    "setup:all": "pnpm run init && pnpm run docker:setup",
    "setup:fresh": "pnpm run init:fresh && pnpm run docker:clean:setup",
    "// --- 📦 Release ---": "",
    "git-tag": "./scripts/git-tag.sh",
    "git-release": "./scripts/git-release.sh"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.18",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.1.1",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@scalar/nestjs-api-reference": "^1.1.10",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "compression": "^1.8.1",
    "helmet": "^8.1.0",
    "kafkajs": "^2.2.4",
    "nest-winston": "^1.10.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.16.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^14.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@clack/prompts": "^1.2.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.0",
    "@nestjs/cli": "^11.0.17",
    "@nestjs/schematics": "^11.0.10",
    "@nestjs/testing": "^11.1.18",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.24",
    "@trivago/prettier-plugin-sort-imports": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.0",
    "@types/node": "^25.5.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "dotenv": "^17.4.1",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.0.1",
    "globals": "^17.5.0",
    "knip": "^6.6.2",
    "lefthook": "^2.1.6",
    "markdownlint-cli": "^0.48.0",
    "picocolors": "^1.1.1",
    "prettier": "^3.4.2",
    "prisma": "^7.7.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.0",
    "unplugin-swc": "^1.5.9",
    "validate-branch-name": "^1.3.2",
    "vitest": "^4.1.4"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "@hono/node-server": ">=1.19.13"
    }
  },
  "validate-branch-name": {
    "pattern": "^(main|master|gh-pages)$|^(feat|fix|chore|docs|style|refactor|perf|test|build|ci|revert|renovate)/.+$",
    "errorMsg": "❌ Invalid branch name. Please use <type>/<description> (e.g., feat/add-api). Allowed types: feat, fix, chore, docs, style, refactor, perf, test, build, ci, revert, renovate"
  }
}
