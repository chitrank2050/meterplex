{
  "name": "meterplex",
  "private": false,
  "version": "0.9.1",
  "description": "Open-source B2B usage metering, entitlements, and billing platform.",
  "homepage": "https://chitrank2050.github.io/meterplex/",
  "author": {
    "name": "Chitrank Agnihotri",
    "email": "chitrank2050@gmail.com",
    "url": "https://www.chitrankagnihotri.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chitrank2050/meterplex"
  },
  "bugs": {
    "url": "https://github.com/chitrank2050/meterplex/issues"
  },
  "sideEffects": false,
  "keywords": [
    "meterplex",
    "metering",
    "entitlements",
    "billing",
    "billing-engine",
    "usage-metering",
    "usage-based-billing",
    "api-monetization",
    "finops",
    "saas",
    "b2b",
    "open-source",
    "nestjs",
    "prisma",
    "kafka",
    "redis",
    "postgres",
    "quota-management",
    "entitlements-engine"
  ],
  "scripts": {
    "// --- 🚀 Core ---": "",
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "// --- 🧹 Hygiene ---": "",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md,yml,yaml}\"",
    "lint": "pnpm run lint:ts && pnpm run lint:md && pnpm run lint:actions && pnpm run lint:knip",
    "lint:ts": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix --max-warnings 0",
    "lint:md": "markdownlint \"**/*.md\" --fix --ignore node_modules --ignore CHANGELOG.md",
    "lint:actions": "zizmor .github/workflows/",
    "lint:branch": "git-hygiene branch",
    "lint:knip": "knip",
    "// --- 🧪 Testing ---": "",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:debug": "vitest --inspect-brk --inspect --logHeapUsage --threads=false",
    "test:e2e": "vitest run --config ./vitest.config.e2e.ts",
    "// --- 💎 Database ---": "",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "// --- 🏗️ Infrastructure ---": "",
    "docker:clean:setup": "./scripts/docker-clean.sh && ./scripts/docker-setup.sh",
    "docker:setup": "./scripts/docker-setup.sh",
    "docker:ui": "docker compose --profile debug up -d",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:clean": "./scripts/docker-clean.sh",
    "docker:logs": "docker compose logs -f",
    "docker:prune": "pnpm docker:down && docker system prune -a -f --volumes",
    "// --- ⚙️ Maintenance ---": "",
    "init": "./scripts/install.sh",
    "nuke": "./scripts/obliviate.sh",
    "init:fresh": "pnpm run nuke && pnpm run init",
    "prepare": "lefthook install",
    "deps:update": "pnpm update --interactive --latest",
    "dev:init": "node ./scripts/wizard.mjs",
    "setup:all": "pnpm run init && pnpm run docker:setup",
    "setup:fresh": "pnpm run init:fresh && pnpm run docker:clean:setup",
    "// --- 📦 Release ---": "",
    "git-tag": "./scripts/git-tag.sh",
    "git-release": "./scripts/git-release.sh"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/terminus": "^11.1.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@scalar/nestjs-api-reference": "^1.2.7",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "compression": "^1.8.1",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "kafkajs": "^2.2.4",
    "nest-winston": "^1.10.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "stripe": "^22.3.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@chitrank2050/git-hygiene": "^0.4.12",
    "@clack/prompts": "^1.6.0",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.27",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.43",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.4",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "dotenv": "^17.4.2",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "knip": "^6.23.0",
    "lefthook": "^2.1.9",
    "markdownlint-cli": "^0.48.0",
    "picocolors": "^1.1.1",
    "prettier": "^3.9.4",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-loader": "^9.6.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.8.0"
  },
  "git-hygiene": {
    "types": [
      "feat",
      "fix",
      "chore",
      "docs",
      "style",
      "refactor",
      "perf",
      "test",
      "build",
      "ci",
      "revert",
      "maintenance",
      "renovate"
    ],
    "ignoreBranches": [
      "main",
      "master",
      "gh-pages"
    ]
  }
}
