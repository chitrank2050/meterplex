{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": [
    "src/main.ts",
    "src/**/*.module.ts",
    "src/common/constants/app.ts",
    "src/common/decorators/skip-audit.decorator.ts",
    "src/common/utils/prisma-errors.ts"
  ],
  "project": ["src/**/*.ts"],
  "ignoreDependencies": [
    "source-map-support",
    "ts-loader",
    "tsconfig-paths",
    "pg",
    "@types/pg",
    "@nestjs/testing",
    "supertest",
    "@types/supertest"
  ],
  "ignoreBinaries": ["zizmor"],
  "ignoreExportsUsedInFile": true,
  "ignoreFiles": ["src/modules/payments/dto/webhook-event-response.dto.ts"]
}
